APP_NAME=PostPilot
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=http://localhost:8000

# ─── Database (MySQL) ──────────────────────────────────────────────────────────
DB_CONNECTION=mysql
DB_HOST=127.0.0.1
DB_PORT=3306
DB_DATABASE=postpilot
DB_USERNAME=root
DB_PASSWORD=your_mysql_password

# ─── Queue (MySQL jobs table) ──────────────────────────────────────────────────
QUEUE_CONNECTION=database

# ─── Cache ────────────────────────────────────────────────────────────────────
CACHE_STORE=database
SESSION_DRIVER=database
SESSION_LIFETIME=120

# ─── Mail (Gmail SMTP) ────────────────────────────────────────────────────────
# Enable 2FA on Gmail → Google Account → Security → App Passwords
MAIL_MAILER=smtp
MAIL_HOST=smtp.gmail.com
MAIL_PORT=587
MAIL_USERNAME=your@gmail.com
MAIL_PASSWORD=your_16_char_app_password
MAIL_ENCRYPTION=tls
MAIL_FROM_ADDRESS=your@gmail.com
MAIL_FROM_NAME="PostPilot"

# ─── Google OAuth (via Laravel Socialite) ─────────────────────────────────────
# From: console.cloud.google.com → APIs → Credentials → OAuth 2.0
GOOGLE_CLIENT_ID=your_google_client_id
GOOGLE_CLIENT_SECRET=your_google_client_secret
GOOGLE_REDIRECT_URI=http://localhost:8000/auth/google/callback

# ─── Meta / Instagram ─────────────────────────────────────────────────────────
# From: developers.facebook.com → Your App → Settings → Basic
META_APP_ID=your_meta_app_id
META_APP_SECRET=your_meta_app_secret
META_REDIRECT_URI=http://localhost:8000/auth/instagram/callback

# ─── Razorpay ─────────────────────────────────────────────────────────────────
# From: dashboard.razorpay.com → Settings → API Keys (use test keys first)
RAZORPAY_KEY_ID=rzp_test_xxxxxxxxxxxx
RAZORPAY_KEY_SECRET=xxxxxxxxxxxxxxxxxxxx

# ─── Anthropic (Claude AI) ────────────────────────────────────────────────────
# From: console.anthropic.com
ANTHROPIC_API_KEY=sk-ant-xxxxxxxxxxxxxxxxxxxx

# ─── Admin ────────────────────────────────────────────────────────────────────
# Generate any long random string: php artisan key:generate --show
ADMIN_SECRET_KEY=change_this_to_a_long_random_string

# ─── Logging ──────────────────────────────────────────────────────────────────
LOG_CHANNEL=stack
LOG_LEVEL=debug
